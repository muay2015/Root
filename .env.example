# OPENAI_API_KEY: Required for OpenAI API calls.
# Generate this in the OpenAI dashboard and keep it out of source control.
OPENAI_API_KEY="your_openai_api_key_here"

# OPENAI_MODEL: Optional override. Defaults to gpt-5.4-mini.
OPENAI_MODEL="gpt-5.4-mini"

# VITE_API_BASE_URL:
# Optional for local development because Vite proxies /api to the local Express server.
# Required only when your frontend and API are deployed to different origins.
# If you deploy this repo to Cloudflare Pages with /functions included, leave this blank.
VITE_API_BASE_URL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase connection options.
# You can use either:
# 1. A single combined value copied from Supabase:
#    VITE_SUPABASE_COMBINED_URL="https://<project-ref>.supabase.co/sb_publishable_<key>"
# 2. Separate project URL and publishable key:
#    VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
#    VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_COMBINED_URL=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
